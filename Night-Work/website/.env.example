# Copy this to `.env` for local Netlify CLI dev.
# In production, set these in Netlify → Site settings → Environment variables instead.

OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Optional — defaults to google/gemini-3.5-flash (released 2026-05-19 at Google I/O 2026).
# Other options on OpenRouter: google/gemini-2.5-flash, anthropic/claude-sonnet-4.6, openai/gpt-4.1, etc.
# OPENROUTER_MODEL=google/gemini-3.5-flash

# Optional — sent as the HTTP-Referer header to OpenRouter for analytics + leaderboard ranking
# SITE_URL=https://visionlink.netlify.app
