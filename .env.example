# VisionLink — environment variables template
# Copy this file to `.env` and fill in. NEVER commit `.env`.

# ---------- AI ----------
GEMINI_API_KEY=your_gemini_api_key_here
# SONIOX_API_KEY=your_soniox_api_key_here   # optional, only if using Soniox STT

# ---------- Supabase ----------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ---------- Worker identity (single-user demo) ----------
WORKER_ID=demo_worker_001
WORKER_NAME=Alaa

# ---------- Email — pick ONE provider ----------

# Path A: Gmail SMTP (5 min setup, sends to anyone)
# Generate the app password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be on first).
SMTP_EMAIL=
SMTP_APP_PASSWORD=
SMTP_FROM_NAME=VisionLink

# Path B: Resend (better deliverability with a verified domain)
# Free sandbox sender 'onboarding@resend.dev' only delivers to the signup
# email until you verify a domain.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=VisionLink <onboarding@resend.dev>
