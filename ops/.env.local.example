# VisionLink Ops — Next.js environment
# Copy to .env.local and fill in.

# Supabase project URL (the same one the Pi uses)
NEXT_PUBLIC_SUPABASE_URL=https://oacuuveluvojfowvktby.supabase.co

# Supabase anon key (the PUBLIC key — safe to ship to browsers).
# Find it at: Supabase dashboard → Project Settings → API → anon public.
# DO NOT use the service_role key here — that key bypasses RLS and would
# leak into every browser request.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
