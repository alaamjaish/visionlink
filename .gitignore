# Secrets
.env

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
venv/

# Logs (local only)
logs/

# Session data (local only) — runtime artefacts, not the Documentation/sessions logs
/sessions/
~/visionlink/sessions/

# Hardware test recordings (runtime artifacts, not source)
tests/hardware/*.mp4
tests/hardware/*.wav
tests/hardware/*.h264
tests/hardware/*.raw

# Dashboard runtime captures
dashboard/static/captures/*.jpg
dashboard/static/captures/*.jpeg
dashboard/static/captures/*.png
!dashboard/static/captures/.gitkeep

# Per-user agent tuning (system prompt, VAD, gains) — set via the
# Agent Settings panel in the dashboard. Local only.
dashboard/agent_settings.json
dashboard/openai_settings.json

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Netlify CLI runtime state (site ID + auth cache)
.netlify/

# npm
node_modules/
